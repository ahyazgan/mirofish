# ==============================================================================
# MiroFish Crypto Trading — Ortam Değişkenleri Şablonu
# ==============================================================================
# Kullanım:
#   cp .env.example .env
#   ve gerçek değerleri doldurun. .env asla git'e commit edilmemelidir.
# ==============================================================================

# === LLM (zorunlu — sentiment analizi için) ===
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# === Haber Kaynakları (en az biri önerilir) ===
CRYPTOPANIC_API_KEY=
NEWSAPI_KEY=
GNEWS_API_KEY=

# === Binance API ===
# TESTNET için (güvenli varsayılan):
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
SIMULATION_MODE=true

# MAINNET canlı işlem için (gerçek para riski!):
#   BINANCE_TESTNET=false
#   SIMULATION_MODE=false
#   ALLOW_MAINNET=true  (açık onay — eksikse config validate() error verir)
ALLOW_MAINNET=false

# === Trading Parametreleri ===
TRACKED_COINS=BTC,ETH,BNB,SOL,XRP,ADA,DOGE,AVAX,DOT,MATIC
MAX_POSITION_SIZE=100
STOP_LOSS_PCT=3.0
TAKE_PROFIT_PCT=5.0
MIN_SENTIMENT_SCORE=0.15

# === Zamanlama (saniye) ===
NEWS_SCAN_INTERVAL=5
PRICE_UPDATE_INTERVAL=30
SIGNAL_EVAL_INTERVAL=60

# === Telegram Bildirim (opsiyonel) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Telegram Listener (opsiyonel — Telethon user-session) ===
# https://my.telegram.org/apps adresinden alın
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=mirofish_listener
TELEGRAM_CHANNELS=

# === Loglama ===
CRYPTO_LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# === Runtime (run_trading.py) ===
TRADING_DURATION_SECONDS=1800
DASHBOARD_PORT=5050
